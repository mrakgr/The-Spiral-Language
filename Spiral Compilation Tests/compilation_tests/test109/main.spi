// A test to see if the type information is flowing from left to right in the correct way.
union rec list a = Nil | Cons : a * list a

// forall 'a 'b. 'a -> ('a -> 'b) -> 'b
inl (|>) forall a b. (a : a) (f : a -> b) : b = real ()
// forall 'a 'b. ('a -> 'b -> 'a) -> 'a -> list 'b -> 'a
inl fold forall a b. (f : a -> b -> a) (s : a) (l : list b) : a = real ()

inl qwe (l : list {x : int}) : int =
    l |> fold (fun a b => b.x) 0

