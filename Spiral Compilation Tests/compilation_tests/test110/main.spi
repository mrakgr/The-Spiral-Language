// Do the type vars get applied correctly.

nominal dict2 k v e = ()

inl qwer forall k v e. () : dict2 k v e = dict2

inl main() =
    inl d : dict2 {x : int} {y : float} {z : int} = qwer ()
    !!!!PrintStatic("=========")
    real
        typecase `d with
        | dict2 ~kk ~vv ~zz =>
            !!!!PrintStatic(`kk)
            !!!!PrintStatic(`vv)
            !!!!PrintStatic(`zz)
    0i32